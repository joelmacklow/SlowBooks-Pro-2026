# If DATABASE_URL is non-empty, it overrides the POSTGRES_* settings below.
DATABASE_URL=

# Full PostgreSQL settings (defaulted for the self-contained Docker stack)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bookkeeper
POSTGRES_USER=bookkeeper
POSTGRES_PASSWORD=bookkeeper
POSTGRES_SSLMODE=disable

APP_HOST=0.0.0.0
APP_PORT=3001
APP_DEBUG=true
BOOTSTRAP_ADMIN_TOKEN=

COMPANY_NAME=My Company
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
DEFAULT_TERMS=Net 30
DEFAULT_TAX_RATE=0.0
