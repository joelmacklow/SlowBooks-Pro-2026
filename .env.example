# If DATABASE_URL is non-empty, it overrides the POSTGRES_* settings below.
DATABASE_URL=

# Full PostgreSQL settings for the self-contained Docker stack.
# Replace POSTGRES_PASSWORD with a long random secret before first run.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=slowbooks
POSTGRES_USER=slowbooks
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_SSLMODE=disable

APP_HOST=0.0.0.0
APP_PORT=3001
APP_DEBUG=false
CORS_ALLOW_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Required for remote first-admin setup. Use a long random value and do not
# place it in URLs, screenshots, tickets, or logs.
BOOTSTRAP_ADMIN_TOKEN=replace-with-a-long-random-bootstrap-token

# Browser sessions are stored in HttpOnly cookies. Set SESSION_COOKIE_SECURE=true
# when SlowBooks is served over HTTPS.
SESSION_COOKIE_NAME=slowbooks_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SECURITY_HEADERS_ENABLE_HSTS=false

# SMTP is environment-owned so app users cannot redirect outbound email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Slowbooks Pro
SMTP_USE_TLS=true

COMPANY_NAME=My Company
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
DEFAULT_TERMS=Net 30
DEFAULT_TAX_RATE=0.0
